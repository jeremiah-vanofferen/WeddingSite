# PostgreSQL database settings
POSTGRES_DB=wedding_db
POSTGRES_USER=wedding_user
POSTGRES_PASSWORD=change_me_db_password

# Backend connection string — must match the values above
DATABASE_URL=postgresql://wedding_user:change_me_db_password@postgres:5432/wedding_db

# Secret used to sign JWTs — use a long random string
JWT_SECRET=change_me_long_random_secret_string

# Admin login credentials — set before first run, used during database initialization
ADMIN_USERNAME=YourName
ADMIN_PASSWORD=change_me_admin_password

# Website name displayed in the navigation bar (optional)
WEBSITE_NAME=My Wedding

# Link to wedding registry (optional)
REGISTRY_LINK=your_registry_link_here

# Admin email for receiving notifications (optional)
ADMIN_EMAIL=youraddress@gmail.com

# Gmail SMTP for sending email notifications (optional)
# Use a Gmail App Password, not your regular Gmail password
# https://support.google.com/accounts/answer/185833
GMAIL_USER=youraddress@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
